# Arquivo de variáveis de ambiente — NÃO faça commit deste arquivo com dados reais!
# Copie este arquivo para .env e preencha os valores.

# === API PNCP ===
PNCP_BASE_URL=https://pncp.gov.br/api/consulta
REQUEST_TIMEOUT=30
MAX_RETRIES=3
RETRY_BACKOFF=2.0
PAGE_SIZE=50

# === ETL ===
BATCH_SIZE=100

# === MongoDB Atlas ===
# Substitua pela sua connection string (formato: mongodb+srv://user:password@cluster.mongodb.net/)
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=pncp
MONGODB_COLLECTION=contratacoes_proposta
